<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <RootNamespace></RootNamespace>
    <AssemblyName>BarangaySystem</AssemblyName>
    <Nullable>enable</Nullable>
    <StartupObject>BarangaySystem.Program</StartupObject>
    <NoWarn>NU1902;NU1903</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="MySql.Data" Version="8.3.0" />
    <PackageReference Include="BCrypt.Net-Next" Version="4.0.3" />
    <PackageReference Include="itext7" Version="8.0.3" />
    <PackageReference Include="EPPlus" Version="7.2.1" />
  </ItemGroup>
  <ItemGroup>
    <EmbeddedResource Include="Resources\logo.jpg" />
  </ItemGroup>
</Project>
